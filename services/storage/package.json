{
  "name": "@noah/storage",
  "version": "0.1.0",
  "private": true,
  "description": "NOAH Encrypted Storage Adapter — AES-256-GCM at-rest encryption",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=verbose",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@noah/eventbus": "workspace:*",
    "@noah/logger": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^1.6.0",
    "typescript": "^5.5.2",
    "vitest": "^1.6.0"
  }
}
